{
  "pluginAlias": "HubspacePlatform",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "required": ["username", "password"],
    "additionalProperties": false,
    "properties": {
      "name": {
        "title": "Plugin Name",
        "type": "string",
        "default": "Hubspace"
      },
      "username": {
        "title": "Hubspace Username (Email)",
        "type": "string",
        "format": "email"
      },
      "password": {
        "title": "Hubspace Password",
        "type": "string"
      },
      "pollingInterval": {
        "title": "Polling Interval (seconds)",
        "type": "integer",
        "default": 30,
        "minimum": 10,
        "description": "How often to poll Hubspace cloud for device state updates."
      },
      "temperatureUnit": {
        "title": "Temperature Unit",
        "type": "string",
        "default": "fahrenheit",
        "oneOf": [
          { "title": "Fahrenheit", "enum": ["fahrenheit"] },
          { "title": "Celsius", "enum": ["celsius"] }
        ],
        "description": "Temperature unit used when communicating with the Hubspace API."
      },
      "otp": {
        "title": "One-Time Password (OTP)",
        "type": "string",
        "description": "Only needed if your account has email 2FA. Hubspace will email you a code after your first login attempt fails. Add it here and restart. Remove it after a successful login — the refresh token is saved automatically."
      },
      "debug": {
        "title": "Enable Debug Logging",
        "type": "boolean",
        "default": false
      }
    }
  },
  "layout": [
    { "key": "username", "type": "email" },
    { "key": "password", "type": "password" },
    {
      "type": "fieldset",
      "title": "Advanced Options",
      "expandable": true,
      "items": ["pollingInterval", "temperatureUnit", "otp", "debug"]
    }
  ]
}
